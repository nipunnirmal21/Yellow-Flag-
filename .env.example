# ── Gemini auth — pick ONE of the two options ──────────────────────────

# Option A · Vertex AI (Google Cloud). This is what Yellow Flag uses.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# Credentials come from EITHER a service-account key file...
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
# ...OR Application Default Credentials: run `gcloud auth application-default login`

# Option B · AI Studio (single API key). Free key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# Optional model overrides (defaults shown)
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001

# API server port (the Vite dev server proxies /api to this)
# PORT=8787

# Optional — RAG retrieval from the knowledge base (server/knowledge/*.md).
# Local:  docker run -p 6333:6333 qdrant/qdrant   ->  QDRANT_URL=http://localhost:6333
# Cloud:  free cluster at https://cloud.qdrant.io ->  set both URL and API key
# QDRANT_URL=
# QDRANT_API_KEY=
