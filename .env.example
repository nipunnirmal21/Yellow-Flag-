# Google Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional model overrides (defaults shown)
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001

# API server port (Vite dev server proxies /api to this)
# PORT=8787

# Optional — enables RAG retrieval from the knowledge base.
# Local:  docker run -p 6333:6333 qdrant/qdrant   →  QDRANT_URL=http://localhost:6333
# Cloud:  free 1GB cluster at https://cloud.qdrant.io  →  set both URL and API key
QDRANT_URL=your-qdrant-url-here
QDRANT_API_KEY=your-qdrant-api-key-here
